<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Claude Code 源代碼外洩事件專題報道 | 2026 科技焦點</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-blue: #00d4ff;
            --primary-purple: #7b2cbf;
            --accent-red: #ff4757;
            --dark-bg: #0a0a0f;
            --card-bg: #12121a;
            --text-primary: #ffffff;
            --text-secondary: #a0a0b0;
            --gradient-1: linear-gradient(135deg, #00d4ff 0%, #7b2cbf 100%);
            --gradient-2: linear-gradient(135deg, #7b2cbf 0%, #ff4757 100%);
            --glow-blue: 0 0 20px rgba(0, 212, 255, 0.5);
            --glow-purple: 0 0 20px rgba(123, 44, 191, 0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Noto Sans TC', sans-serif;
            background-color: var(--dark-bg);
            color: var(--text-primary);
            line-height: 1.8;
            overflow-x: hidden;
        }

        /* 動畫效果 */
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes codeRain {
            0% { transform: translateY(-100%); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(100vh); opacity: 0; }
        }

        /* 代碼雨背景 */
        .code-rain {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .code-char {
            position: absolute;
            color: var(--primary-blue);
            font-family: 'Courier New', monospace;
            font-size: 14px;
            opacity: 0;
            animation: codeRain 4s linear infinite;
        }

        /* Hero Section */
        .hero {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px 20px;
            background: linear-gradient(180deg, var(--dark-bg) 0%, #1a1a2e 100%);
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(ellipse at center, rgba(123, 44, 191, 0.15) 0%, transparent 70%);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            max-width: 1200px;
            text-align: center;
            animation: slideIn 1s ease-out;
        }

        .hero-badge {
            display: inline-block;
            padding: 8px 24px;
            background: var(--gradient-1);
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 24px;
            box-shadow: var(--glow-blue);
        }

        .hero h1 {
            font-size: clamp(2rem, 5vw, 4rem);
            font-weight: 900;
            margin-bottom: 24px;
            background: var(--gradient-1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1.2;
        }

        .hero-subtitle {
            font-size: clamp(1.1rem, 2vw, 1.4rem);
            color: var(--text-secondary);
            max-width: 800px;
            margin: 0 auto 40px;
        }

        .hero-images {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
            margin-top: 60px;
        }

        .hero-image-card {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            aspect-ratio: 16/9;
            box-shadow: var(--glow-purple);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .hero-image-card:hover {
            transform: scale(1.02);
            box-shadow: 0 0 40px rgba(123, 44, 191, 0.7);
        }

        .hero-image-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .scroll-indicator {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            animation: float 2s ease-in-out infinite;
            z-index: 2;
        }

        .scroll-indicator span {
            display: block;
            width: 30px;
            height: 50px;
            border: 2px solid var(--primary-blue);
            border-radius: 25px;
            position: relative;
        }

        .scroll-indicator span::before {
            content: '';
            position: absolute;
            top: 8px;
            left: 50%;
            transform: translateX(-50%);
            width: 6px;
            height: 10px;
            background: var(--primary-blue);
            border-radius: 3px;
            animation: pulse 1.5s infinite;
        }

        /* Section Styles */
        section {
            padding: 100px 20px;
            position: relative;
            z-index: 1;
        }

        .section-title {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-title h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 700;
            margin-bottom: 16px;
            background: var(--gradient-1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .section-title p {
            color: var(--text-secondary);
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Timeline Section */
        .timeline-section {
            background: linear-gradient(180deg, #1a1a2e 0%, var(--dark-bg) 100%);
        }

        .timeline {
            max-width: 1000px;
            margin: 0 auto;
            position: relative;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 4px;
            height: 100%;
            background: var(--gradient-1);
            border-radius: 2px;
        }

        .timeline-item {
            display: flex;
            justify-content: flex-end;
            padding: 20px 0;
            position: relative;
            width: 50%;
        }

        .timeline-item:nth-child(even) {
            align-self: flex-end;
            margin-left: 50%;
            justify-content: flex-start;
        }

        .timeline-content {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 16px;
            max-width: 450px;
            margin: 0 40px;
            border: 1px solid rgba(0, 212, 255, 0.2);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .timeline-content:hover {
            transform: translateY(-5px);
            box-shadow: var(--glow-blue);
        }

        .timeline-dot {
            position: absolute;
            width: 20px;
            height: 20px;
            background: var(--primary-blue);
            border-radius: 50%;
            top: 35px;
            right: -10px;
            box-shadow: var(--glow-blue);
        }

        .timeline-item:nth-child(even) .timeline-dot {
            right: auto;
            left: -10px;
        }

        .timeline-time {
            color: var(--primary-blue);
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 8px;
        }

        .timeline-content h3 {
            font-size: 1.3rem;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        .timeline-content p {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        /* Key Points Section */
        .key-points-section {
            background: var(--dark-bg);
        }

        .key-points-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .key-point-card {
            background: var(--card-bg);
            padding: 40px 30px;
            border-radius: 20px;
            border: 1px solid rgba(123, 44, 191, 0.3);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .key-point-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--gradient-2);
        }

        .key-point-card:hover {
            transform: translateY(-10px);
            box-shadow: var(--glow-purple);
            border-color: var(--primary-purple);
        }

        .key-point-icon {
            font-size: 3rem;
            margin-bottom: 20px;
        }

        .key-point-card h3 {
            font-size: 1.4rem;
            margin-bottom: 16px;
            color: var(--text-primary);
        }

        .key-point-card p {
            color: var(--text-secondary);
            line-height: 1.8;
        }

        /* Impact Section */
        .impact-section {
            background: linear-gradient(180deg, var(--dark-bg) 0%, #1a1a2e 100%);
        }

        .impact-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto 60px;
        }

        .stat-card {
            text-align: center;
            padding: 40px 20px;
            background: var(--card-bg);
            border-radius: 20px;
            border: 1px solid rgba(0, 212, 255, 0.2);
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 900;
            background: var(--gradient-1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 10px;
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .impact-content {
            max-width: 900px;
            margin: 0 auto;
            background: var(--card-bg);
            padding: 50px;
            border-radius: 24px;
            border: 1px solid rgba(255, 71, 87, 0.3);
        }

        .impact-content h3 {
            font-size: 1.8rem;
            margin-bottom: 30px;
            color: var(--accent-red);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .impact-list {
            list-style: none;
        }

        .impact-list li {
            padding: 15px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: flex-start;
            gap: 15px;
        }

        .impact-list li:last-child {
            border-bottom: none;
        }

        .impact-list li::before {
            content: '⚠️';
            font-size: 1.2rem;
        }

        /* Response Section */
        .response-section {
            background: var(--dark-bg);
        }

        .response-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .response-card {
            background: var(--card-bg);
            padding: 40px;
            border-radius: 20px;
            border-left: 4px solid var(--primary-blue);
        }

        .response-card h3 {
            font-size: 1.5rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .response-card p {
            color: var(--text-secondary);
            line-height: 1.8;
        }

        /* Footer */
        footer {
            background: #050508;
            padding: 60px 20px;
            text-align: center;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        footer p {
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: var(--primary-blue);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-links a:hover {
            color: var(--text-primary);
        }

        /* RWD */
        @media (max-width: 768px) {
            .timeline::before {
                left: 20px;
            }

            .timeline-item,
            .timeline-item:nth-child(even) {
                width: 100%;
                margin-left: 0;
                padding-left: 50px;
                justify-content: flex-start;
            }

            .timeline-dot,
            .timeline-item:nth-child(even) .timeline-dot {
                left: 10px;
                right: auto;
            }

            .timeline-content {
                margin: 0;
                max-width: 100%;
            }

            .hero-images {
                grid-template-columns: 1fr;
            }

            .impact-stats {
                grid-template-columns: repeat(2, 1fr);
            }

            .impact-content {
                padding: 30px 20px;
            }
        }

        @media (max-width: 480px) {
            .impact-stats {
                grid-template-columns: 1fr;
            }

            .stat-number {
                font-size: 2.5rem;
            }

            .response-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- 代碼雨背景 -->
    <div class="code-rain" id="codeRain"></div>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <span class="hero-badge">🔥 2026 科技焦點事件</span>
            <h1>Claude Code 源代碼外洩事件</h1>
            <p class="hero-subtitle">
                Anthropic「王牌」產品 51.2 萬行源代碼因 npm 配置疏忽遭完整洩露<br>
                安全研究員意外發現，引發全球 AI 業界震動
            </p>
            
            <div class="hero-images">
                <div class="hero-image-card">
                    <img src="./20260404_122039_qwen-image-plus.png" alt="AI 代碼安全概念圖">
                </div>
                <div class="hero-image-card">
                    <img src="./20260404_122055_qwen-image-plus.png" alt="網絡安全警告概念圖">
                </div>
            </div>
        </div>
        
        <div class="scroll-indicator">
            <span></span>
        </div>
    </section>

    <!-- Timeline Section -->
    <section class="timeline-section">
        <div class="section-title">
            <h2>⏱️ 事件時間線</h2>
            <p>從洩露到發現，一場現實版的「代碼大偷渡」</p>
        </div>
        
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-time">📅 2026 年 3 月 31 日 14:00</div>
                    <h3>Anthropic 發布新版本</h3>
                    <p>Anthropic 在 npm 倉庫發布 @anthropic-ai/claude-code v2.1.88 版本，卻意外將包含完整源代碼的 59.8MB 偵錯用 cli.js.map 文件打包其中。</p>
                </div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-time">📅 2026 年 3 月 31 日 16:30</div>
                    <h3>安全研究員發現漏洞</h3>
                    <p>Web3 安全公司 FuzzLand 實習研究員 Chaofan Shou（@Fried_rice）率先發現並披露這一漏洞，文件中的 sourcesContent 字段直接包含完整源碼。</p>
                </div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-time">📅 2026 年 3 月 31 日 晚间</div>
                    <h3>消息引爆硅谷</h3>
                    <p>安全大佬 Chaofan Shou 的帖子瞬間在整個硅谷引爆，引來 2200 多萬人圍觀。科技圈上演了一場現實版的「代碼大偷渡」。</p>
                </div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-time">📅 2026 年 4 月 1-3 日</div>
                    <h3>全网瘋狂克隆</h3>
                    <p>GitHub 上出現大量 Claude Code「換殼」克隆項目，Anthropic 緊急封殺但為時已晚。開發者紛紛下載研究這 51.2 萬行珍貴代碼。</p>
                </div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-time">📅 2026 年 4 月 4 日</div>
                    <h3>事件持續發酵</h3>
                    <p>各大科技媒體爭相報道，分析此次洩露對 AI 行業的影響。國產 AI 編程工具被認為迎來發展機遇。</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Key Points Section -->
    <section class="key-points-section">
        <div class="section-title">
            <h2>🔑 事件關鍵要點</h2>
            <p>這次洩露為何如此轟動？五大關鍵因素解析</p>
        </div>
        
        <div class="key-points-grid">
            <div class="key-point-card">
                <div class="key-point-icon">💾</div>
                <h3>51.2 萬行完整源碼</h3>
                <p>洩露的不是片段代碼，而是包含完整核心邏輯的 51.2 萬行源代碼，甚至包括開發人員的手寫註釋，可直接還原 Claude Code 的全部功能。</p>
            </div>
            
            <div class="key-point-card">
                <div class="key-point-icon">🐛</div>
                <h3>低級配置錯誤</h3>
                <p>幾乎所有開發者都熟悉的低級錯誤：npm 註冊表中的 map 文件配置疏忽，導致 sourcesContent 字段包含完整源碼，本應只包含符號映射。</p>
            </div>
            
            <div class="key-point-card">
                <div class="key-point-icon">🔓</div>
                <h3>50+ 工具架構曝光</h3>
                <p>洩露代碼揭示了 Claude Code 的代理循環（agent loop）、50 多個工具集成、多代理協作架構，以及尚未發布的功能特性。</p>
            </div>
            
            <div class="key-point-card">
                <div class="key-point-icon">⚡</div>
                <h3>Anthropic 封殺失敗</h3>
                <p>Anthropic 試圖緊急下架並封殺相關項目，但代碼已在 GitHub 上被瘋狂克隆，「換殼」版本層出不窮，封殺行動宣告失敗。</p>
            </div>
            
            <div class="key-point-card">
                <div class="key-point-icon">🌏</div>
                <h3>國產 AI 迎來機遇</h3>
                <p>分析認為，此次洩露讓國內開發者得以學習頂尖 AI 編程工具的架構設計，國產 AI 編程工具可能迎來重要發展機遇。</p>
            </div>
            
            <div class="key-point-card">
                <div class="key-point-icon">📊</div>
                <h3>2200 萬人圍觀</h3>
                <p>事件在社交媒體上引發巨大關注，超過 2200 萬人圍觀討論，成為 2026 年科技圈最轟動的安全事件之一。</p>
            </div>
        </div>
    </section>

    <!-- Impact Section -->
    <section class="impact-section">
        <div class="section-title">
            <h2>⚠️ 事件影響分析</h2>
            <p>這次洩露對 AI 行業意味著什麼？</p>
        </div>
        
        <div class="impact-stats">
            <div class="stat-card">
                <div class="stat-number">51.2 萬</div>
                <div class="stat-label">洩露代碼行數</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">59.8 MB</div>
                <div class="stat-label">洩露文件大小</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">2200 萬+</div>
                <div class="stat-label">社交媒體圍觀人次</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">50+</div>
                <div class="stat-label">暴露工具數量</div>
            </div>
        </div>
        
        <div class="impact-content">
            <h3>🚨 主要影響與風險</h3>
            <ul class="impact-list">
                <li><strong>商業機密洩露：</strong>Claude Code 作為 Anthropic 的「王牌」產品，其核心算法、架構設計、工具集成等商業機密完全暴露，可能影響公司競爭優勢。</li>
                <li><strong>安全漏洞風險：</strong>源代碼公開後，安全研究人員和黑客均可分析潛在漏洞，可能引發後續安全攻擊。</li>
                <li><strong>知識產權爭議：</strong>大量克隆項目出現，可能引發版權糾紛和法律訴訟，但取證和維權難度極大。</li>
                <li><strong>行業競爭格局變化：</strong>競爭對手可藉此優化自身產品，國產 AI 編程工具可能加速追趕，改變市場格局。</li>
                <li><strong>開發流程反思：</strong>事件促使整個行業重新審視 CI/CD 流程、代碼打包和發布安全檢查機制。</li>
            </ul>
        </div>
    </section>

    <!-- Response Section -->
    <section class="response-section">
        <div class="section-title">
            <h2>📢 各方回應</h2>
            <p>事件曝光後，相關方的反應與措施</p>
        </div>
        
        <div class="response-grid">
            <div class="response-card">
                <h3>🏢 Anthropic 官方</h3>
                <p>Anthropic 緊急下架受影響的 npm 包版本，嘗試通過 DMCA 通知移除 GitHub 上的克隆項目。公司發表聲明承認「打包配置錯誤」，表示已加強內部審查流程，但未透露具體損失評估。</p>
            </div>
            
            <div class="response-card">
                <h3>👨‍💻 發現者 Chaofan Shou</h3>
                <p>Web3 安全公司 FuzzLand 實習研究員 Chaofan Shou 在社交媒體詳細披露了漏洞細節，包括如何從 map 文件中提取完整源碼。他的帖子成為事件發酵的起點，獲得業界廣泛關注。</p>
            </div>
            
            <div class="response-card">
                <h3>🌐 開發者社區</h3>
                <p>GitHub 上出現大量「Claude Code Unpacked」、「Claude Code 解析」等項目，開發者熱烈討論代碼架構。部分開發者認為這是「學習頂級 AI 工具的絕佳機會」，也有人呼籲尊重知識產權。</p>
            </div>
            
            <div class="response-card">
                <h3>📰 科技媒體</h3>
                <p>36 氪、鈦媒體、搜狐科技等主流科技媒體爭相報道，分析此次洩露對 AI 行業的深遠影響。多數評論認為這是「AI 發展史上最大的源代碼洩露事件之一」。</p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 AI Gen 網頁專題報道 | 本頁面由 AI 技術生成</p>
        <div class="footer-links">
            <a href="#">關於本專題</a>
            <a href="#">資料來源</a>
            <a href="#">隱私政策</a>
            <a href="#">聯絡我們</a>
        </div>
    </footer>

    <script>
        // 代碼雨效果
        function createCodeRain() {
            const codeRain = document.getElementById('codeRain');
            const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン';
            const fontSize = 14;
            const columns = Math.floor(window.innerWidth / fontSize);
            
            for (let i = 0; i < 50; i++) {
                const char = document.createElement('div');
                char.className = 'code-char';
                char.textContent = chars[Math.floor(Math.random() * chars.length)];
                char.style.left = Math.random() * 100 + '%';
                char.style.animationDelay = Math.random() * 4 + 's';
                char.style.animationDuration = (Math.random() * 2 + 3) + 's';
                codeRain.appendChild(char);
            }
        }

        // 滾動動畫
        function handleScrollAnimation() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.timeline-content, .key-point-card, .stat-card, .response-card').forEach(el => {
                el.style.opacity = '0';
                el.style.transform = 'translateY(30px)';
                el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
                observer.observe(el);
            });
        }

        // 數字動畫
        function animateStats() {
            const stats = document.querySelectorAll('.stat-number');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const target = entry.target;
                        const text = target.textContent;
                        const num = parseFloat(text.replace(/[^0-9.]/g, ''));
                        if (!isNaN(num)) {
                            let current = 0;
                            const increment = num / 50;
                            const timer = setInterval(() => {
                                current += increment;
                                if (current >= num) {
                                    current = num;
                                    clearInterval(timer);
                                }
                                target.textContent = text.replace(/[0-9.]+/, current.toFixed(0));
                            }, 30);
                        }
                        observer.unobserve(target);
                    }
                });
            }, { threshold: 0.5 });

            stats.forEach(stat => observer.observe(stat));
        }

        // 平滑滾動
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            createCodeRain();
            handleScrollAnimation();
            animateStats();
        });

        // 視窗調整時重新計算
        window.addEventListener('resize', () => {
            document.getElementById('codeRain').innerHTML = '';
            createCodeRain();
        });
    </script>
</body>
</html>
